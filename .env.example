# Copy to .env.local and fill in. .env.local is gitignored.

# Claude Agent SDK auth — use ONE of these:
#   CLAUDE_CODE_OAUTH_TOKEN: a Claude subscription token from `claude setup-token` (sk-ant-oat-...)
#   ANTHROPIC_API_KEY:       a standard API key (sk-ant-api-...) — leave OAuth token unset if you use this
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# Model — any Claude model the SDK supports. Optional; defaults to claude-sonnet-4-6.
LLM_MODEL=claude-sonnet-4-6

# Persistence + auth (now required — the app is fully gated behind sign-in).
# Create a Neon project and enable Neon Auth (Auth tab). In Auth → Configuration:
# turn on email sign-up + "Verify at Sign-up" (verification code), leave OAuth off.
DATABASE_URL=

# Neon Auth (managed, Better Auth). From Neon console → Auth → Configuration:
#   NEON_AUTH_BASE_URL = the "Auth URL" shown under Project Info
NEON_AUTH_BASE_URL=
# Cookie signing secret, 32+ chars: openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET=

# 32-byte key for app-level AES-256-GCM encryption of stored PII.
# Generate with: openssl rand -base64 32
DATA_ENCRYPTION_KEY=

# Agent runtime: "inprocess" (local dev, default) or "sandbox" (Vercel Sandbox).
# On Vercel, set to "sandbox"; locally leave unset.
# AGENT_RUNTIME=inprocess
# AGENT_SANDBOX_SNAPSHOT_ID=
