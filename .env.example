# Copy to .env.local and fill in. .env.local is gitignored.

# LLM — any OpenAI-compatible, tool-use-capable endpoint. Defaults target Groq's free tier.
# LLM_MODEL drives the tool-calling loop; LLM_PLAN_MODEL assembles the structured plan
# (must support structured outputs). Both are optional — sensible Groq defaults are built in.
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_PLAN_MODEL=openai/gpt-oss-120b

# Persistence + auth (Phases 5-7, not needed for the demo)
# DATABASE_URL=
# NEXT_PUBLIC_STACK_PROJECT_ID=
# NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
# STACK_SECRET_SERVER_KEY=
