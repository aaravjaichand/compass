# Copy to .env.local and fill in. .env.local is gitignored.

# Claude Agent SDK auth — use ONE of these:
#   CLAUDE_CODE_OAUTH_TOKEN: a Claude subscription token from `claude setup-token` (sk-ant-oat-...)
#   ANTHROPIC_API_KEY:       a standard API key (sk-ant-api-...) — leave OAuth token unset if you use this
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=

# Model — any Claude model the SDK supports. Optional; defaults to claude-sonnet-4-6.
LLM_MODEL=claude-sonnet-4-6

# Persistence + auth (Phases 5-7, not needed for the demo)
# DATABASE_URL=
# NEXT_PUBLIC_STACK_PROJECT_ID=
# NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
# STACK_SECRET_SERVER_KEY=
